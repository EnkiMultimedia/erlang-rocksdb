{application, rocksdb,
 [
  {description, "RocksDB for Erlang"},
  {vsn, "2.6.1"},
  {registered, []},
  {applications, [
          kernel,
          stdlib
         ]},
  {env, []},

  {licenses, ["Apache-2.0"]},
  {links, [{"Github", "https://github.com/EnkiMultimedia/erlang-rocksdb"}]},
  {files, ["rebar.config",
           "rebar.config.script",
           "do_cmake.sh",
           "do_rocksdb.sh",
           "README.md",
           "LICENSE",
           "CHANGELOG.md",
           "GETTING_STARTED.md",
           "CUSTOMIZED_BUILDS.md",
           "guides",
           "src",
           "deps",
           "c_src",
           "test"]},
  {exclude_files, [
    "doc",
    "deps/rebar3",
    %% rocksdb exclusions
    "deps/rocksdb/java",
    "deps/rocksdb/docs",
    "deps/rocksdb/db_stress_tool",
    "deps/rocksdb/buckifier",
    "deps/rocksdb/fuzz",
    "deps/rocksdb/coverage",
    %% zstd exclusions (9.5M -> ~3.5M)
    "deps/zstd/tests",
    "deps/zstd/doc",
    "deps/zstd/contrib",
    "deps/zstd/build",
    "deps/zstd/programs",
    "deps/zstd/zlibWrapper",
    "deps/zstd/examples",
    %% snappy exclusions (8.9M -> ~0.5M)
    "deps/snappy/third_party",
    "deps/snappy/testdata",
    %% lz4 exclusions
    "deps/lz4/tests",
    "deps/lz4/doc",
    "deps/lz4/programs",
    "deps/lz4/contrib",
    "deps/lz4/examples",
    "deps/lz4/ossfuzz",
    %% CRoaring exclusions
    "deps/CRoaring/tests",
    "deps/CRoaring/benchmarks",
    "deps/CRoaring/microbenchmarks"
  ]}

 ]}.
